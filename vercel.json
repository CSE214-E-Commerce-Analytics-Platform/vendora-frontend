{
  "buildCommand": "npm run build -- --configuration production",
  "outputDirectory": "dist/vendora-frontend/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://HETZNER_IP_OR_DOMAIN:8080/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
